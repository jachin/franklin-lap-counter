{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "python@3.13.3",
    "python313Packages.textual@latest",
    "redis@latest",
    "python313Packages.pip@latest",
    "python313Packages.typing-extensions@latest",
    "basedpyright@latest",
    "pyright@latest",
    "python313Packages.redis@latest",
    "python313Packages.ruff@latest",
    "python313Packages.aiohttp@latest",
    "python313Packages.pygments@latest",
    "python313Packages.rich@latest",
    "rustup@latest",
    "pkg-config@latest",
    "tmux@latest",
    "tmuxinator@latest",
    "ansible@latest",
    "lnav@latest",
    "gtk4@latest",
    "python313Packages.pygobject3@latest",
    "biome@latest"
  ],

  "shell": {
    "init_hook": [
      ". $VENV_DIR/bin/activate",
      "redis-server --daemonize yes --unixsocket ./redis.sock --unixsocketperm 700"
    ],
    "scripts": {
      "full-sim": ["tmuxinator start -p tmuxinator/full-sim.yml"],
      "full-sim-attach": ["tmux attach-session -t franklin-full-sim"],
      "full-sim-stop": ["tmux kill-session -t franklin-full-sim"],
      "lint": [
        "devbox run lint:python",
        "devbox run lint:web",
        "devbox run lint:rust"
      ],
      "lint:python": [
        "ruff check franklin-tui.py franklin-gui.py scoreboard_web_app.py referee_web_app.py healthcheck_web_app.py database.py race",
        "basedpyright franklin-tui.py franklin-gui.py scoreboard_web_app.py referee_web_app.py healthcheck_web_app.py database.py race"
      ],
      "lint:web": ["biome check --files-ignore-unknown=true static"],
      "lint:rust": ["cargo check --manifest-path rust/Cargo.toml"],
      "test": ["devbox run test:python", "devbox run test:rust"],
      "test:python": [
        "python -m unittest discover -s race -t . -p '*_test.py'"
      ],
      "test:rust": ["cargo test --manifest-path rust/Cargo.toml"],
      "rust-build": ["cargo build --manifest-path rust/Cargo.toml"],
      "rust-pi-build": ["./scripts/rust-pi-build.sh"],
      "rust-build-release": [
        "cargo build --release --manifest-path rust/Cargo.toml"
      ],
      "ansible:setup": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/site.yml"
      ],

      "ansible:web-bounce": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/62-bounce-web-apps.yml"
      ],
      "ansible:reboot": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/63-reboot.yml"
      ],
      "vnc:open-tunnel": [
        "echo 'Opening SSH tunnel localhost:5901 -> 127.0.0.1:5900 on Pi (Ctrl+C to stop)'",
        "ssh -N -L 5901:127.0.0.1:5900 jachin@10.27.1.64"
      ],
      "vnc:connect": ["open vnc://127.0.0.1:5901"],
      "ansible:deploy": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/deploy-franklin.yml"
      ],

      "ansible:health-check": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/61-health-check.yml"
      ]
    }
  }
}

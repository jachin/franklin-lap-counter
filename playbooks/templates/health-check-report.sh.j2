#!/usr/bin/env bash

set +e
cd "{{ pi_dest_dir }}"

echo "=== terminal + terminfo ==="
echo "TERM=${TERM:-unset}"
if infocmp -x xterm-ghostty >/dev/null 2>&1; then
  echo "xterm-ghostty terminfo: present"
else
  echo "xterm-ghostty terminfo: missing"
fi
if TERM=xterm-ghostty tmux ls >/dev/null 2>&1; then
  echo "tmux with TERM=xterm-ghostty: ok"
else
  echo "tmux with TERM=xterm-ghostty: failed"
fi
echo

echo "=== tmux sessions ==="
tmux ls || true
echo

echo "=== redis socket + ping ==="
ls -l ./redis.sock || true
redis-cli -s ./redis.sock PING || true
echo

echo "=== hardware:out heartbeat sample (6s) ==="
timeout 6 redis-cli -s ./redis.sock SUBSCRIBE hardware:out 2>/dev/null | grep -m1 '"type":"heartbeat"' || true
echo

echo "=== referee web app process + health ==="
pgrep -af referee_web_app.py | grep -v "bash -lc" || echo "referee_web_app.py not running"
python3 - <<'PY'
import json
import urllib.request

url = "http://127.0.0.1:8081/api/health"
try:
    with urllib.request.urlopen(url, timeout=3) as response:
        payload = response.read().decode("utf-8", "replace")
    data = json.loads(payload)
    if data.get("ok") is True:
        print("referee /api/health: ok")
    else:
        print("referee /api/health: unexpected payload", payload)
except Exception as exc:
    print(f"referee /api/health: failed ({exc})")
PY
echo

echo "=== caddy service + proxy checks ==="
systemctl is-active caddy.service || true
python3 - <<'PY'
import urllib.request

def check(url: str, host: str) -> None:
    req = urllib.request.Request(url, headers={"Host": host})
    try:
        with urllib.request.urlopen(req, timeout=3) as response:
            status = response.status
        print(f"{host} via caddy: HTTP {status}")
    except Exception as exc:
        print(f"{host} via caddy: failed ({exc})")

check("http://127.0.0.1/", "{{ franklin_scoreboard_domain }}")
check("http://127.0.0.1/api/health", "{{ franklin_referee_domain }}")
PY
echo

echo "=== wayvnc process/port ==="
pgrep -af wayvnc | grep -v "bash -lc" || echo "wayvnc not running"
ss -lnt | grep ":{{ franklin_wayvnc_port }} " || true
echo

echo "=== emoji font availability ==="
if fc-list | grep -qi "Noto Color Emoji"; then
  echo "Noto Color Emoji: present"
else
  echo "Noto Color Emoji: missing"
fi
echo

echo "=== gui.log errors (last 120 lines) ==="
tail -n 120 ./gui.log | grep -E "Traceback|TypeError|Redis connect failed|ERROR" || echo "No matching GUI errors found"
echo

echo "=== hardware_redis.log (last 20) ==="
tail -n 20 ./hardware_redis.log || true

exit 0

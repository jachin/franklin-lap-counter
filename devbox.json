{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "python@3.13.3",
    "python313Packages.textual@latest",
    "redis@latest",
    "python313Packages.pip@latest",
    "python313Packages.typing-extensions@latest",
    "basedpyright@latest",
    "pyright@latest",
    "python313Packages.redis@latest",
    "python313Packages.ruff@latest",
    "python313Packages.aiohttp@latest",
    "python313Packages.pygments@latest",
    "python313Packages.rich@latest",
    "rustup@latest",
    "pkg-config@latest",
    "tmux@latest",
    "tmuxinator@latest",
    "ansible@latest",
    "lnav@latest",
    "gtk4@latest",
    "python313Packages.pygobject3@latest",
    "biome@latest",
    "watchexec@latest",
    "gobject-introspection@latest",
    "pango@latest",
    "graphene@latest",
    "harfbuzz@latest",
    "pango.dev",
    "cairo@latest",
    "gdk-pixbuf@latest"
  ],
  "env": {
    "GI_TYPELIB_PATH": "$GI_TYPELIB_PATH:$(${pkgs.lib.makeSearchPathOutput \"lib\" \"lib/girepository-1.0\" [ pkgs.gtk4 pkgs.pango pkgs.gdk-pixbuf pkgs.gobject-introspection ]})"
  },
  "shell": {
    "init_hook": [
      "export GI_TYPELIB_PATH=\"$DEVBOX_PACKAGES_DIR/lib/girepository-1.0:/nix/store/88695svqh0ii3c8ax51vgkv53rsdfnwn-pango-1.57.1/lib/girepository-1.0:/nix/store/f5q5qhflsijx1drbsanwcjx0m9l717ix-gdk-pixbuf-2.44.6/lib/girepository-1.0:$GI_TYPELIB_PATH\"",
      "redis-server --daemonize yes --unixsocket ./redis.sock --unixsocketperm 700"
    ],
    "scripts": {
      "start:franklin": ["tmuxinator start -p tmuxinator/franklin.yml"],
      "start:franklin-simulator": [
        "tmuxinator start -p tmuxinator/franklin-simulator.yml"
      ],
      "web_scoreboard": ["python scoreboard_web_app.py"],
      "web_referee": ["python referee_web_app.py"],
      "web_healthcheck": ["python healthcheck_web_app.py"],
      "web_driver": ["python driver_web_app.py"],
      "race_recorder": ["python franklin-race-recorder.py"],
      "race_recorder:shadow": ["python franklin-race-recorder.py --shadow"],
      "db:end-all-races": ["python scripts/db_end_all_races.py"],
      "lint": [
        "devbox run lint:python",
        "devbox run lint:web",
        "devbox run lint:rust"
      ],
      "lint:python": [
        "ruff check franklin-tui.py franklin-gui.py franklin-race-recorder.py scoreboard_web_app.py referee_web_app.py healthcheck_web_app.py driver_web_app.py database.py race",
        "basedpyright franklin-tui.py franklin-gui.py franklin-race-recorder.py scoreboard_web_app.py referee_web_app.py healthcheck_web_app.py driver_web_app.py database.py race"
      ],
      "lint:web": ["biome check --files-ignore-unknown=true static"],
      "lint:rust": ["cargo check --manifest-path rust/Cargo.toml"],
      "test": ["devbox run test:python", "devbox run test:rust"],
      "test:python": [
        "python -m unittest discover -s race -t . -p '*_test.py'"
      ],
      "test:rust": ["cargo test --manifest-path rust/Cargo.toml"],
      "build": ["devbox run build:pi", "devbox run build:release"],
      "build:pi": ["./scripts/rust-pi-build.sh"],
      "build:release": [
        "cargo build --release --manifest-path rust/Cargo.toml"
      ],
      "ansible:setup": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/site.yml"
      ],

      "ansible:web-bounce": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/62-bounce-web-apps.yml"
      ],
      "ansible:reboot": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/63-reboot.yml"
      ],
      "vnc:open-tunnel": [
        "echo 'Opening SSH tunnel localhost:5901 -> 127.0.0.1:5900 on Pi (Ctrl+C to stop)'",
        "ssh -N -L 5901:127.0.0.1:5900 jachin@10.210.1.1"
      ],
      "vnc:connect": ["open vnc://127.0.0.1:5901"],
      "ansible:deploy": [
        "devbox run build:pi",
        "ansible-playbook -i playbooks/inventory.ini playbooks/deploy-franklin.yml"
      ],
      "ansible:deploy-gui": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/deploy-franklin-gui.yml"
      ],
      "ansible:reset-db": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/64-reset-database.yml"
      ],
      "deploy-gui": [
        "devbox run ansible:deploy-gui",
        "devbox run ansible:web-bounce"
      ],

      "ansible:health-check": [
        "ansible-playbook -i playbooks/inventory.ini playbooks/61-health-check.yml"
      ]
    }
  }
}
